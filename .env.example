# ─────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the blanks. NEVER commit `.env`.
# Anything secret lives here, never in code.
# ─────────────────────────────────────────────────────────────────────────

# ========================== LLM — BRING ANY KEY ==========================
# Steward talks to the LLM through the OpenAI SDK, so it works with ANY OpenAI-compatible
# provider: OpenRouter (default), OpenAI, Together, Groq, DeepSeek, or a local vLLM/Ollama
# server. You only need ONE provider + ONE key.
#
# EASIEST (OpenRouter — one key, access to every model): leave LLM_PROVIDER=openrouter,
# get a key at https://openrouter.ai/keys, paste it below, done.
#
# To use a DIFFERENT provider, set all three LLM_* vars and the *_MODEL ids to that
# provider's model names. Examples:
#   OpenAI:    LLM_PROVIDER=openai    LLM_BASE_URL=https://api.openai.com/v1   models like gpt-4o-mini
#   Together:  LLM_PROVIDER=other     LLM_BASE_URL=https://api.together.xyz/v1
#   Local:     LLM_PROVIDER=other     LLM_BASE_URL=http://localhost:11434/v1   (Ollama)
# (The per-task `reasoning` budget is an OpenRouter feature other gateways ignore harmlessly.)
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_BASE_URL=
# Back-compat fallback (used only if LLM_API_KEY/LLM_BASE_URL above are blank):
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model ids for your chosen provider. The TaskRouter (llm/router.py) picks per task; these
# are the defaults it draws from. judge/noise/draft = fast path; pro = critical path.
# (Defaults below are OpenRouter slugs — change them to your provider's model names.)
JUDGE_MODEL=google/gemini-2.5-flash
NOISE_MODEL=google/gemini-2.5-flash
DRAFT_MODEL=google/gemini-2.5-flash
PRO_MODEL=google/gemini-2.5-pro

# Addresses that are the PRINCIPAL themselves — inbound from these is NEVER processed
# (e.g. Jatin's other inboxes). Comma-separated.
SELF_ADDRESSES=

# --- Gmail (OAuth "installed app" desktop flow) ---
# Download the OAuth client (Desktop app) from Google Cloud Console and point
# GMAIL_CREDENTIALS_PATH at the downloaded client_secret JSON.
# The token cache is created on first run after you complete the browser flow.
GMAIL_CREDENTIALS_PATH=./secrets/client_secret.json
GMAIL_TOKEN_PATH=./secrets/gmail_token.json
# The Gmail address this account belongs to (used for "from me" voice mining).
GMAIL_ADDRESS=you@example.com

# --- Gmail push notifications (P0a — OPT-IN; default = polling) ---
# Set a Pub/Sub topic to get email→Telegram in <10s instead of waiting for the poll.
# Empty = polling only (the always-on fallback). See INTELLIGENCE.md → Push for setup.
# e.g. projects/my-project/topics/gmail-push
GMAIL_PUBSUB_TOPIC=
# Localhost port the push receiver binds (a tunnel forwards Pub/Sub here).
GMAIL_PUBSUB_PORT=8001

# --- Calendar context (P4a — OPT-IN) ---
# true adds the calendar.readonly scope (forces a one-time re-consent on next run)
# so the brain knows your week and the drafter can propose real open slots.
CALENDAR_ENABLED=false

# --- Telegram control surface ---
# Create a bot via @BotFather, paste the token here.
TELEGRAM_BOT_TOKEN=123456:ABC-...
# Your personal chat id (the bot ONLY ever talks to / obeys this id).
# Find it by messaging the bot, then GET https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_CHAT_ID=

# --- Behaviour ---
# dry_run  = classify + draft, change NOTHING in Gmail, only log what it WOULD do (default, safe)
# live     = actually archive/label and send approved replies
MODE=dry_run

# Master toggle for the Gmail channel (the Mac app flips this). false = run WhatsApp-only.
EMAIL_ENABLED=true

# How often to poll Gmail for new mail, in seconds.
POLL_INTERVAL_SECONDS=45

# Confidence (0..1) below which a CONSEQUENTIAL item is surfaced to you instead
# of acted on. Higher = more cautious. Start conservative.
SURFACE_CONFIDENCE_THRESHOLD=0.75

# In conservative calibration, even Tier 0/1 actions need at least this much
# confidence or they get bumped up to "ask me". Set 0 to disable.
AUTONOMY_CONFIDENCE_THRESHOLD=0.85

# Importance (0..100) at or above which a contact is treated as a VIP.
VIP_IMPORTANCE_THRESHOLD=70

# Draft quality gate (P5b): auto-fix em-dashes/filler, flag fabrication/over-length.
QUALITY_GATE_ENABLED=true

# --- Cross-channel memory (see MEMORY.md) ---
# Master switch. If off (or if any memory step fails) the brain classifies on the
# thread alone, exactly as before — memory is additive and never breaks the inbox.
MEMORY_ENABLED=true
# Distill the relationship record after each non-noise message + after a send.
MEMORY_DISTILL_ENABLED=true
# Surface "is this the same person?" merge questions to Telegram (Yes/No).
LINK_SUGGESTIONS_ENABLED=true
# Don't re-surface a situation you skipped within this many hours (nudge cooldown).
MEMORY_NUDGE_COOLDOWN_HOURS=24

# --- Storage / paths ---
DB_PATH=./data/assistant.db
LOG_PATH=./data/assistant.log
PROMPTS_DIR=./prompts

# Local timezone for morning/evening briefs (IANA name).
TIMEZONE=America/Los_Angeles
MORNING_BRIEF_HOUR=8
EVENING_BRIEF_HOUR=18
# Hour (local) for the daily commitment + stale-thread check (P4b).
COMMITMENT_CHECK_HOUR=8

# --- WhatsApp relay (Phase 2 — off by default) ---
# Set true AND run the Node relay (see WHATSAPP.md) to activate the WhatsApp channel.
WHATSAPP_ENABLED=false
# Python receiver listens here for /inbound from the relay; relay listens on send port.
WHATSAPP_RELAY_PORT=7999
WHATSAPP_SEND_PORT=7998
# Comma-separated WhatsApp JIDs treated as PERSONAL — always surfaced (Tier 3), never auto-handled.
# e.g. 919876543210@s.whatsapp.net
PERSONAL_JIDS=
# VIP "always-instant": you hear about them immediately (skips the settling delay) and
# they are never quieted. e.g. 919812345678@s.whatsapp.net
VIP_JIDS=
# MUTE "never": silently handled, never pings you — but a genuinely consequential
# message (money/legal/irreversible) still surfaces via the hard guardrail floor.
MUTE_JIDS=
# In group chats, only act on a message if it @mentions you OR contains one of these words.
WATCH_KEYWORDS=urgent,decision,asap
# Your own WhatsApp JID, for @mention detection in groups.
WA_USER_JID=
# Audio-capable model (via OpenRouter) used to transcribe voice notes.
WHATSAPP_TRANSCRIBE_MODEL=google/gemini-2.5-flash

# --- WhatsApp settling / debounce ---
# People text line-by-line. Instead of a Telegram ping per line, hold a conversation's
# burst until it goes QUIET, then process the whole thing as ONE card. Durable in
# SQLite, so a restart never drops or double-sends a message. Set false for the old
# instant per-message behaviour.
WHATSAPP_SETTLE_ENABLED=true
# 1:1 chats: seconds of silence before a burst is released.
WHATSAPP_SETTLE_SECONDS=75
# 1:1 safety cap: even a slow trickle surfaces within this many seconds (15 min).
WHATSAPP_SETTLE_MAX_HOLD_SECONDS=900
# Groups have natural lulls and we never ping while one is active: wait far longer.
WHATSAPP_GROUP_SETTLE_SECONDS=300
# Group safety cap (3 h) so a deadline in a still-trickling group still eventually surfaces.
WHATSAPP_GROUP_MAX_HOLD_SECONDS=10800

# --- Presence / context / learning (Layer 1) ---
# Don't ping about a chat you're handling yourself. The agent still TRACKS everything.
PRESENCE_SUPPRESSION_ENABLED=true
# You replied in a chat within this many seconds → stay silent on it.
PRESENCE_OUTBOUND_COOLDOWN_SECONDS=300
# Also stay quiet while the native WhatsApp Mac app is frontmost (a browser tab can't be detected).
PRESENCE_APP_FOCUS_ENABLED=true
# How many days of a chat's history to feed the brain as context.
WHATSAPP_CONTEXT_DAYS=14
# Learn your WhatsApp texting style from your own sent messages.
WHATSAPP_STYLE_ENABLED=true
# After this many skips (with ~no approvals) for a sender, surface them more quietly.
FEEDBACK_TUNING_ENABLED=true
FEEDBACK_SKIP_THRESHOLD=3

# --- Production hardening (audit phases) ---
# Phase 6: per-fact memory confidence/decay/verification (weak memories fade, strong strengthen).
MEMORY_GOVERNANCE_ENABLED=true
# Phase 9: daily proactive digest (unanswered VIPs, at-risk commitments, stalled threads).
PROACTIVE_ENABLED=true
PROACTIVE_HOUR=9
# Phase 11: retention/pruning of high-volume logs/metrics/decisions; relay health alarm.
RETENTION_ENABLED=true
RETENTION_DAYS=90
RETENTION_WA_HISTORY_DAYS=30
RELAY_HEALTH_ALERT_ENABLED=true
# Phase 11b OPT-IN auth (empty = localhost-bind-only, current behavior). Set BOTH to a long
# random string to require X-Cos-Token on the relay->engine ingest and on web console writes.
# If you set INGEST_TOKEN, also export it for the relay process (same value).
INGEST_TOKEN=
CONSOLE_TOKEN=

# --- Mini App (optional — enables the Telegram Mini App surface) ---
MINIAPP_URL=                    # HTTPS URL serving the dashboard; empty = disabled
MINIAPP_SECRET=                 # JWT signing secret; defaults to bot token if empty

# --- LLM-based thread enrichment ---
OPPORTUNITY_DETECTION_ENABLED=true
PROJECT_TAGGING_ENABLED=true

# --- Scheduling ---
# Hour (24h, local timezone) for the daily state update job.
STATE_UPDATE_HOUR=7

# ─────────────────────────────────────────────────────────────────────────────
# Reconstruction hardening knobs (all OPTIONAL — safe defaults shown; read from env)
# ─────────────────────────────────────────────────────────────────────────────
# Gmail history-gap resync window (days) — how far back to rescan after a >24h outage
# so older mail is never silently dropped (finding ingest-email-1 / NO_SILENT_LOSS).
GMAIL_RESYNC_DAYS=7

# (INGEST_TOKEN is defined once above, in the Production-hardening section.)

# Gmail Pub/Sub PUSH receiver auth (ingest-email-6 / config-secrets-deploy-3). A
# high-entropy shared secret required on incoming push POSTs; empty = accept-with-warning.
GMAIL_PUSH_TOKEN=
GMAIL_PUSH_MIN_INTERVAL_SECONDS=0      # debounce rapid push wakes (0 = off)

# LLM cost/availability guards (llm-layer-4). <=0 disables a given guard.
LLM_DAILY_SPEND_CAP_USD=25.0
LLM_RATE_LIMIT_BREAKER_THRESHOLD=5     # consecutive 429s before the breaker opens
LLM_RATE_LIMIT_BREAKER_COOLDOWN_S=60
LLM_MEDIA_MAX_BYTES=12582912           # cap on transcribe/describe input media (12 MiB)

# WhatsApp settling/fairness (ingest-whatsapp-6 / ingest-whatsapp-7 / config-secrets-deploy-4).
WHATSAPP_VIP_INSTANT_SETTLE_SECONDS=0  # 0 = instant VIP (default); >0 = coalesce VIP bursts
WA_POLL_DEBOUNCE_S=2                   # coalesce rapid forced /poll hits
WHATSAPP_INBOX_PER_JID_CAP=20          # per-conversation fairness cap in the settle window

# Identity: path to the relay's LID→phone-JID map (memory-identity-3).
STEWARD_LID_JID_MAP_PATH=relay/lid_jid_map.json
